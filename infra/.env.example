# ── AWS: use CLI profile / default credential chain ─────────────────────────
# Do not put access keys here unless you really want to. Typical workflow:
#   export AWS_PROFILE=my-profile
#   export AWS_DEFAULT_REGION=eu-west-1
#   pnpm --dir infra run deploy
# Optional: pin account for the stack (must match the profile’s account):
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=eu-west-1

# ── App env (optional): copied onto Lambda at synth/deploy ──────────────────
# Loaded when the CDK app runs (see lib/load-env.ts). Omit to set in console/SSM.
# JWT_SECRET=
# JWT_ISSUER=
# JWT_AUDIENCE=
# ENABLE_DEV_ENDPOINTS=true
