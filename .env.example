# Aurora DSQL - same variables as Lambda (`DSQL_*`). App and SQL migrations use IAM; no local Postgres.
DSQL_ENDPOINT=<CDK output DatabaseEndpoint>
DSQL_REGION=eu-west-1
# Optional (defaults match CDK): DSQL_USER=admin  DSQL_DATABASE=postgres
# Optional token lifetime for CLI only (seconds): DSQL_TOKEN_EXPIRES=3600
#
# `pnpm run db:migrate` loads `.env` and applies SQL files from `sql/migrations`.
# Your IAM principal needs `dsql:DbConnectAdmin` on the cluster.

# HS256; must match the key used to sign tokens
JWT_SECRET=change-me-in-production
# Optional claims validation:
# JWT_ISSUER=
# JWT_AUDIENCE=

# When "1" / "true" / "yes", enables POST /dev/seed and GET /dev/token for local demos (off in production).
# ENABLE_DEV_ENDPOINTS=true
