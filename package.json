{
  "name": "qred-assignment",
  "type": "module",
  "scripts": {
    "build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 ./src/index.ts",
    "zip": "zip -j lambda.zip dist/index.js",
    "update": "aws lambda update-function-code --zip-file fileb://lambda.zip --function-name hello",
    "deploy": "run-s build zip update",
    "db:migrate": "esbuild scripts/migrate-dsql.ts --bundle --platform=node --target=node20 --outfile=./dist/migrate-dsql.cjs && node ./dist/migrate-dsql.cjs",
    "db:dsql-url": "bash scripts/dsql-database-url.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "cdk:synth": "pnpm --dir infra exec cdk synth",
    "cdk:deploy": "pnpm --dir infra exec cdk deploy",
    "cdk:diff": "pnpm --dir infra exec cdk diff",
    "cdk:destroy": "pnpm --dir infra exec cdk destroy"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.21.4",
    "npm-run-all2": "^6.2.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1038.0",
    "@aws-sdk/dsql-signer": "^3.1038.0",
    "@aws/aurora-dsql-node-postgres-connector": "^0.1.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
